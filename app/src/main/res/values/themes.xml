<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ConFin" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores primarios - Ocean Blue -->
        <item name="colorPrimary">@color/ocean_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ocean_blue_light</item>
        <item name="colorOnPrimaryContainer">@color/charcoal_brown</item>

        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/ash_grey</item>
        <item name="colorOnSecondary">@color/charcoal_brown</item>
        <item name="colorSecondaryContainer">@color/ash_grey_light</item>
        <item name="colorOnSecondaryContainer">@color/charcoal_brown</item>

        <!-- Colores terciarios - Forest Green -->
        <item name="colorTertiary">@color/forest_green</item>
        <item name="colorOnTertiary">@color/white</item>

        <!-- Fondo -->
        <item name="android:colorBackground">@color/ash_grey</item>
        <item name="colorSurface">@color/ash_grey_light</item>
        <item name="colorOnSurface">@color/charcoal_brown</item>
        <item name="colorSurfaceVariant">@color/ash_grey_dark</item>

        <!-- Error - Red -->
        <item name="colorError">@color/red_main</item>
        <item name="colorOnError">@color/white</item>

        <!-- Outline -->
        <item name="colorOutline">@color/ash_grey_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/charcoal_brown</item>
        <item name="android:navigationBarColor">@color/ash_grey</item>
    </style>

    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/ocean_blue</item>
        <item name="hintTextColor">@color/charcoal_brown</item>
        <item name="boxBackgroundColor">@color/white</item>
    </style>

    <style name="Theme.ConFin" parent="Base.Theme.ConFin">
        <!-- Botones -->
        <item name="materialButtonStyle">@style/ConFin.Button</item>
    </style>

    <!-- Estilo de botón personalizado -->
    <style name="ConFin.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/ocean_blue</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Estilo de botón secundario -->
    <style name="ConFin.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/ocean_blue</item>
        <item name="android:textColor">@color/ocean_blue</item>
    </style>
</resources>