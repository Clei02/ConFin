<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Incluir preferencias compartidas -->
    <include domain="sharedpref" path="."/>
    
    <!-- Excluir preferencias de sesión (datos de login) - por seguridad -->
    <exclude domain="sharedpref" path="ConFinPrefs.xml"/>
    
    <!-- No hacer backup de base de datos (Firebase lo maneja) -->
    <exclude domain="database" path="."/>
    <exclude domain="external" path="."/>
</full-backup-content>